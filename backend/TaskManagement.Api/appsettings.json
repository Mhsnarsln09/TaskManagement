{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "BackgroundJobs": {
    "Enabled": true
  },
  "Database": {
    "MigrateOnStartup": false
  },
  "BootstrapAdmin": {
    "Enabled": false
  },
  "Jwt": {
    "Issuer": "TaskManagement.Api",
    "Audience": "TaskManagement.Api",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 14,
    "ClockSkewSeconds": 30
  },
  "FileUpload": {
    "MaxSizeInBytes": 5242880,
    "AllowedExtensions": [ ".png", ".jpg", ".jpeg", ".gif", ".pdf", ".txt", ".csv" ],
    "AllowedContentTypes": [
      "image/png",
      "image/jpeg",
      "image/gif",
      "application/pdf",
      "text/plain",
      "text/csv"
    ]
  },
  "FileStorage": {
    "Local": {
      "RootPath": "App_Data/attachments"
    }
  },
  "AllowedHosts": "*"
}
